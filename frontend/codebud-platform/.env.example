# ── codebud-platform environment ─────────────────────────────────────────────
# Copy to .env.local for dev; set these in the hosting provider for prod.

# Flask backend URL. The browser calls it DIRECTLY (cross-origin; the backend's
# CORS_ORIGINS allowlist must include this app's origin). The Next middleware
# also calls it server-side.
# Dev: http://localhost:5000   Prod: https://auth.mycodebud.in
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:5000
# Optional server-side override for the middleware (falls back to the above).
BACKEND_BASE_URL=http://localhost:5000

# Keycloak (browser exchanges the auth code directly with Keycloak).
NEXT_PUBLIC_KEYCLOAK_URL=https://keycloak.mycodebud.in
NEXT_PUBLIC_KEYCLOAK_REALM=codebud
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=codebud-app

# DSA code execution strategy (browser-first with server fallback).
NEXT_PUBLIC_USE_BROWSER_FIRST=true
NEXT_PUBLIC_FALLBACK_TO_SERVER=true
