# MongoDB Configuration (LOCAL DEVELOPMENT)
# For now, using local MongoDB or MongoDB Docker container
MONGODB_URI=mongodb://localhost:27017/
DATABASE_NAME=codebud_dev

# Production placeholder (will be provided by senior dev)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/codebud?retryWrites=true&w=majority

# AWS S3 Configuration (PLACEHOLDERS)
# Mock S3 using local file system for now
USE_MOCK_S3=true
MOCK_S3_PATH=./mock_s3_storage

# Production placeholder (will be provided by DevOps)
# AWS_ACCESS_KEY_ID=PLACEHOLDER_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=PLACEHOLDER_SECRET_KEY
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=codebud-storage

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production

# JWT Configuration (for backwards compatibility)
JWT_SECRET=codebud-jwt-secret-dev-2026
JWT_EXPIRY_HOURS=72

# Keycloak Configuration
# Enable Keycloak authentication by setting these values
# Leave empty to use standard JWT authentication
KEYCLOAK_SERVER_URL=http://localhost:8080/
KEYCLOAK_REALM=codebud
KEYCLOAK_CLIENT_ID=codebud-backend
KEYCLOAK_CLIENT_SECRET=

# Keycloak Admin Credentials (for user management)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=

# Production Keycloak Configuration (placeholder)
# KEYCLOAK_SERVER_URL=https://auth.codebud.com/
# KEYCLOAK_REALM=codebud-production
# KEYCLOAK_CLIENT_ID=codebud-backend
# KEYCLOAK_CLIENT_SECRET=<client-secret-from-keycloak>
# KEYCLOAK_ADMIN_USERNAME=admin
# KEYCLOAK_ADMIN_PASSWORD=<admin-password>
